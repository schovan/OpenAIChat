<Window x:Class="AIPChatApp.Views.ApiKeyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="Enter Google API Key" Width="400" SizeToContent="Height"
        Background="#343541"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Please enter your Google API Key:" 
                   Foreground="#ECECF1" 
                   FontSize="14" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10" 
                   Grid.Row="0"/>
                   
        <TextBox Text="{Binding Result, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="1" 
                 Margin="0,0,0,20"
                 Background="#40414F" 
                 Foreground="White" 
                 Padding="12"
                 BorderThickness="0"
                 FontSize="14">
            <TextBox.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </TextBox.Resources>
        </TextBox>
        
        <Button Content="Save" 
                Grid.Row="2" 
                Width="100" 
                HorizontalAlignment="Right"
                Background="#19c37d" 
                Foreground="White"
                Padding="15,8"
                FontSize="14"
                FontWeight="SemiBold"
                Cursor="Hand"
                BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Click">
                    <i:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                        MethodName="Close"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
    </Grid>
</Window>
